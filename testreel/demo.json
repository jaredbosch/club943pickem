{
  "url": "https://thepickempool.com/sign-in",
  "viewport": { "width": 1440, "height": 900 },
  "colorScheme": "dark",
  "outputFormat": "mp4",
  "speed": 0.8,

  "cursor": {
    "style": "pointer",
    "size": 44,
    "rippleColor": "rgba(255, 255, 255, 0.35)",
    "rippleSize": 90,
    "idleHide": true,
    "idleHideMs": 4000,
    "fadeMs": 350
  },

  "chrome": {
    "enabled": true,
    "titleBarHeight": 38,
    "titleBarColor": "#1a1a1a",
    "trafficLights": true,
    "url": "thepickempool.com"
  },

  "background": {
    "enabled": true,
    "gradient": { "from": "#0a0a0a", "to": "#111827" },
    "padding": 60,
    "borderRadius": 14
  },

  "setup": {
    "steps": [
      { "action": "wait", "ms": 800 },
      { "action": "fill", "selector": "#email", "text": "matt.thompson.tpp@mailinator.com" },
      { "action": "fill", "selector": "#password", "text": "SeedUser2026!!" },
      { "action": "click", "selector": "button[type=submit]" },
      { "action": "wait", "ms": 5000 }
    ]
  },

  "steps": [

    { "action": "navigate", "url": "https://thepickempool.com/league/6V7A3F/picks?week=1", "pauseAfter": 1800 },
    { "action": "screenshot", "name": "01-picks-week7" },
    { "action": "scroll", "y": 120, "pauseAfter": 800 },
    { "action": "screenshot", "name": "02-picks-games" },
    { "action": "scroll", "y": 200, "pauseAfter": 800 },
    { "action": "screenshot", "name": "03-picks-more-games" },
    { "action": "hover", "selector": ".ps-budget-bar", "pauseAfter": 1000 },
    { "action": "screenshot", "name": "04-budget-bar" },
    { "action": "wait", "ms": 800 },

    { "action": "navigate", "url": "https://thepickempool.com/league/6V7A3F/grid?week=7", "pauseAfter": 1800 },
    { "action": "screenshot", "name": "05-grid-loaded" },
    { "action": "scroll", "x": 300, "y": 0, "pauseAfter": 900 },
    { "action": "screenshot", "name": "06-grid-mid" },
    { "action": "scroll", "x": 350, "y": 0, "pauseAfter": 900 },
    { "action": "screenshot", "name": "07-grid-full" },
    { "action": "scroll", "y": 200, "pauseAfter": 800 },
    { "action": "screenshot", "name": "08-grid-bottom" },
    { "action": "wait", "ms": 800 },

    { "action": "navigate", "url": "https://thepickempool.com/league/6V7A3F/commissioner", "pauseAfter": 1800 },
    { "action": "screenshot", "name": "09-commissioner" },
    { "action": "scroll", "y": 280, "pauseAfter": 900 },
    { "action": "screenshot", "name": "10-member-roster" },
    { "action": "scroll", "y": 280, "pauseAfter": 800 },
    { "action": "screenshot", "name": "11-league-settings" },
    { "action": "wait", "ms": 800 },

    { "action": "navigate", "url": "https://thepickempool.com/league/6V7A3F/dashboard", "pauseAfter": 2000 },
    { "action": "screenshot", "name": "12-dashboard" },
    { "action": "scroll", "y": 200, "pauseAfter": 900 },
    { "action": "screenshot", "name": "13-standings" },
    { "action": "scroll", "y": 300, "pauseAfter": 900 },
    { "action": "screenshot", "name": "14-weekly-results" },
    { "action": "wait", "ms": 1500 }

  ]
}
